# ─── Cuadros de Carga Platform — Variables de entorno ───────────────────────
# Copiar este archivo como .env y completar los valores

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Cuadros de Carga — Alumbrado Público"
DEBUG=false

# ── Base de datos ─────────────────────────────────────────────────────────────
# Desarrollo (SQLite, sin configuración adicional):
DATABASE_URL=sqlite:///./cuadros_carga.db

# Producción (PostgreSQL en Render/Railway):
# DATABASE_URL=postgresql+psycopg2://usuario:contraseña@host:5432/nombre_db

# ── Almacenamiento ────────────────────────────────────────────────────────────
# Desarrollo (archivos locales en ./uploads/):
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Producción — AWS S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=sa-east-1
# S3_BUCKET_NAME=cuadros-carga

# Producción — MinIO (self-hosted):
# STORAGE_TYPE=minio
# AWS_ACCESS_KEY_ID=minio_user
# AWS_SECRET_ACCESS_KEY=minio_password
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET_NAME=cuadros-carga

# Producción — Cloudflare R2:
# STORAGE_TYPE=r2
# AWS_ACCESS_KEY_ID=<r2_access_key_id>
# AWS_SECRET_ACCESS_KEY=<r2_secret_access_key>
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_BUCKET_NAME=cuadros-carga
# S3_PUBLIC_URL_BASE=https://pub-<hash>.r2.dev

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-en-produccion-32chars-min

# ── URLs presigned S3 (tiempo de validez en segundos) ─────────────────────────
PRESIGNED_URL_EXPIRES=3600
